# ════════════════════════════════════════════════════════════════
# COFIRA - Variables de entorno (PLANTILLA)
# ────────────────────────────────────────────────────────────────
# Copia este archivo a .env y rellena los valores reales:
#     cp .env.example .env
# El archivo .env está en .gitignore y NUNCA se sube al repositorio.
# ════════════════════════════════════════════════════════════════

# --- Base de datos PostgreSQL ---
DB_USERNAME=admin
# Usa una contraseña fuerte y única:
DB_PASSWORD=cambia_esta_password

# --- JWT ---
# Genera un secreto nuevo (mínimo 64 bytes). Ejemplo para generarlo:
#     openssl rand -hex 64
JWT_SECRET=genera_un_secreto_con_openssl_rand_hex_64
JWT_EXPIRATION_MS=86400000

# --- pgAdmin (solo desarrollo) ---
PGADMIN_EMAIL=admin@cofira.com
PGADMIN_PASSWORD=cambia_esta_password

# --- Servicio de IA (OpenRouter) ---
OPENROUTER_API_KEY=tu_api_key_de_openrouter
OPENROUTER_MODEL=openai/gpt-4o-mini
